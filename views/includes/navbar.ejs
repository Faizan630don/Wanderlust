<style>
  .btn-search {
    background-color: #ff385c;
    color: white;
    border: none;
    border-radius: 15rem;
    padding: 0.5rem 1rem;
  }
  .btn-search:hover {
    background-color: #ff385c;
    color: white;
  }
  .btn-search i{
    display: inline;
    margin-right: 0.5rem;
  }
  .search-inp{
    border-radius: 15rem;
    width: 250px;
    padding: 0.5rem 2rem 0.5rem 2rem;
    font-size: 1rem;
  }
  
  /* Mobile search form styling */
  @media (max-width: 767.98px) {
    .search-inp {
      width: 100%;
      margin-bottom: 0.5rem;
      font-size: 0.9rem;
    }
    
    .btn-search {
      width: 100%;
      padding: 0.6rem 1rem;
      font-size: 0.9rem;
    }
    
    /* Mobile navbar adjustments */
    .navbar-nav.ms-auto {
      flex-direction: column;
      width: 100%;
    }
    
    .navbar-nav.ms-auto form {
      width: 100%;
      margin-bottom: 1rem;
    }
  }
</style>

<nav class="navbar navbar-expand-md bg-body-light border-bottom sticky-top">
    <div class="container-fluid">
      <a class="navbar-brand" href="/listings"><i class="fa-solid fa-compass" style="color: #ff2600;"></i></a>
      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav" aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
      </button>
      <div class="collapse navbar-collapse" id="navbarNav">
        <ul class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/listings">Explore</a>
          </li>
        </ul>
        
        <!-- Desktop Search Form (hidden on mobile) -->
        <div class="navbar-nav mx-auto d-none d-md-flex">
          <form class="d-flex" role="search" method="GET" action="/listings">
            <input name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" class="form-control me-2 search-inp" type="search" placeholder="Search Destinations" />
            <button class="btn btn-search search-btn" type="submit"> <i class="fa-solid fa-magnifying-glass">&nbsp;&nbsp;Search</i></button>
          </form>
        </div>
        
        <div class="navbar-nav">
          <li class="nav-item">
            <a class="nav-link" href="/listings/new">Airbnb your home</a>
          </li> 
        <% if(!currUser) { %>
        <a class="nav-link" href="/signup"><b>Sign Up</b></a>
        <a class="nav-link" href="/login"><b>Log In</b></a>
        <% }%> <% if(currUser) {%>
        <a class="nav-link" href="/logout"><b>Log Out</b></a>
        <%}%>
      </div>
    </div>
  </nav>

  