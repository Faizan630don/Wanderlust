<% layout("/layouts/boilerplate") %>

<!-- Mobile Search Bar (only visible on mobile) -->
<div class="mobile-search-container d-md-none">
    <form class="d-flex" role="search" method="GET" action="/listings">
        <input name="q" value="<%= typeof query !== 'undefined' ? query : '' %>" class="form-control mobile-search-input" type="search" placeholder="Search Destinations" />
        <button class="btn mobile-search-btn" type="submit">
            <i class="fa-solid fa-magnifying-glass"></i>
        </button>
    </form>
</div>

<style>
    #filters {
        display: flex;
        gap: 1rem;
        overflow-x: auto;
        padding: 1rem 0;
        flex-wrap: wrap;
    }
    .filter{
        text-align: center;
        
        border-radius: 1.4rem;
        padding: 0.2rem 0.8rem;
       
        cursor: pointer;
        background-color: white;
        flex: 0 0 auto;
        transition: box-shadow 0.3s ease;}
    .filter:hover{
        box-shadow: 0 4px 8px rgba(0,0,0,1);
        scale: 1.05;
    }
    .filter p{
        font-size: 0.7rem;
        margin: 0;
        padding: 0;
    }
    .taxInfo{
      display: none;  
        font-size: 0.85rem;
        color: gray;

        
    }
    .taxToggle{
        margin-left: auto;
        margin-bottom: 10px;
        align-self: center;
        box-shadow: 0 4px 8px rgba(0,0,0,0.5);
        flex: 0 0 auto;
        border: 1px solid black;
        border-radius: 0.8rem;
        padding: 0.2rem 0.8rem;
        background-color: white;
        cursor: pointer;
        transition: box-shadow 0.3s ease;
        
        
    }
    
    /* Mobile Search Bar */
    .mobile-search-container {
        padding: 0.75rem 1rem;
        background: white;
        border-bottom: 1px solid #e9ecef;
        margin-bottom: 0.5rem;
    }
    
    .mobile-search-input {
        border-radius: 25px;
        border: 1px solid #ddd;
        padding: 0.5rem 1rem;
        font-size: 0.9rem;
        flex: 1;
    }
    
    .mobile-search-input:focus {
        border-color: #ff385c;
        box-shadow: 0 0 0 0.2rem rgba(255, 56, 92, 0.15);
    }
    
    .mobile-search-btn {
        background-color: #ff385c;
        color: white;
        border: none;
        border-radius: 50%;
        width: 40px;
        height: 40px;
        margin-left: 0.5rem;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    
    .mobile-search-btn:hover {
        background-color: #e22b4e;
        color: white;
    }
    
    /* Mobile Filter Arrow Button */
    .mobile-filter-arrow {
        position: absolute;
        right: 10px;
        top: 35%;
        transform: translateY(-50%);
        background: rgba(255, 56, 92, 0.9);
        color: white;
        border: none;
        border-radius: 50%;
        width: 35px;
        height: 35px;
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 10;
        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
        transition: all 0.3s ease;
        
    }
    
    .mobile-filter-arrow:hover {
        background: rgba(255, 56, 92, 1);
        transform: translateY(-50%) scale(1.1);
    }
    
    .mobile-filter-arrow.rotated {
        transform: translateY(-50%) rotate(180deg);
    }
    
    /* Mobile filter container positioning */
    @media (max-width: 767.98px) {
        #filters {
            position: relative;
            overflow: hidden;
            max-width: 100%;
        }
        
        #filters .filter:nth-child(n+5) {
            display: none;
        }
        
        #filters.expanded .filter:nth-child(n+5) {
            display: flex;
        }
    }
</style>
<div id="filters" >
    <!-- Mobile Arrow Button (only visible on mobile) -->
    <button id="mobileFilterArrow" class="mobile-filter-arrow d-md-none ">
        <i class="fa-solid fa-chevron-down"></i>
    </button>
    
    <div class="filter m-1">
        <div><i class="fa-solid fa-fire"></i></div>
        <p>Trending</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-bed"></i></div>
        <p>Rooms</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-mountain-city "></i></div>
        <p>Iconic Cities</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-mountain"></i></div>
        <p>Mountains</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-chess-rook"></i></div>
        <p>Castles</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-person-swimming"></i></div>
        <p>Amazing Pools</p>
    </div> 
    <div class="filter">
        <div><i class="fa-solid fa-cow "></i></div>
        <p>Farms</p>
    </div>
    <div class="filter">
        <div><i class="fa-regular fa-snowflake"></i></div>
        <p>Arctic</p>
    </div> 
    <div class="filter">
        <div><i class="fa-solid fa-campground"></i></div>
        <p>Camping</p>
    </div>
    <div class="filter">
        <div><i class="fa-solid fa-landmark-dome"></i></div>
        <p>Domes</p>
    </div> 
    <div class="filter">
        <div><i class="fa-solid fa-ship"></i></div>
        <p>Boats</p>
    </div>
   
    <div class="taxToggle">
        <div class="form-check-reverse form-switch">
            <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
            <label class="form-check-label" for="switchCheckDefault">Display Total after Taxes</label>
          </div>
    </div>
    
</div>
    
    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 mt-3">
    <% for(let listing of allListings) { %>
        <a href="/listings/<%= listing._id %>" class="listing-link">

    <div class="card col listing-card ">
        <img src="<%= listing.image.url || listing.image %>" class="card-img-top" alt="listing_image" style="height: 20rem;">

        <div class="card-body">
          <h6 class="card-title ms-3 mt-1"> <%= listing.title%></h6>
          <p class="card-text">
            <p class="ms-3">&#8377; <%= listing.price ? listing.price.toLocaleString("en-IN") : 'N/A' %> / night
            <i class="taxInfo"> &nbsp;  &nbsp;+18% GST</i></p>

            </p>
          
        </div>
      </div></a>
      <% }%>
     </div>
    
<script>
    let taxSwitch = document.getElementById('switchCheckDefault');
    taxSwitch.addEventListener("click", () => {
     let taxInfo = document.querySelectorAll('.taxInfo');
     for(info of taxInfo){
        if(taxSwitch.checked){
            info.style.display = 'inline';
        } else {
            info.style.display = 'none';
        }
     }
    })
    
    // Mobile filter arrow functionality
    document.addEventListener('DOMContentLoaded', function() {
        const mobileArrow = document.getElementById('mobileFilterArrow');
        const filtersContainer = document.getElementById('filters');
        
        if (mobileArrow && filtersContainer) {
            mobileArrow.addEventListener('click', function() {
                filtersContainer.classList.toggle('expanded');
                mobileArrow.classList.toggle('rotated');
                
                // Change arrow direction
                const icon = mobileArrow.querySelector('i');
                if (filtersContainer.classList.contains('expanded')) {
                    icon.className = 'fa-solid fa-chevron-up';
                } else {
                    icon.className = 'fa-solid fa-chevron-down';
                }
            });
        }
    });
</script>